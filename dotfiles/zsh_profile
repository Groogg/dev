# Set up fzf key bindings and fuzzy completion
source <(fzf --zsh)

# Vim
alias vim='nvim'

# Git
alias gl='git pull'
alias gp='git push'
alias gpu='git push -u origin "$(git branch --show-current)"'
alias gpf='git push --force'
alias gst='git stash'
alias gs='git status'
alias gb='git branch'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gd='git diff'
alias ga='git add'
alias gaa='git add .'
alias gc='git commit'
alias gcm='git commit -m'

