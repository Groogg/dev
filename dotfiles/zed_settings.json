{
  "vim_mode": true,
  "buffer_font_size": 18,
  "wrap_guides": [80],
  "theme": "One Dark",
  "scrollbar": {
    "show": "never"
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "format_on_save": "on",
  "indent_guides": { "enabled": false },
  "assistant": {
      "default_model": {
        "provider": "zed.dev",
        "model": "claude-3-5-sonnet-latest"
      },
      "version": "2"
    }
}
